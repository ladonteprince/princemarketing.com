# Production app URL (no trailing slash)
API_BASE=https://princemarketing.com

# Shared secret with the production VPS .env. Generate with:
#   openssl rand -hex 32
# Both this file AND /var/www/princemarketing.com/.env must have the
# IDENTICAL value, or the agent's poll requests will be rejected with 403.
FINISHING_AGENT_TOKEN=

# Where finished videos upload (GCS bucket — same as production app)
GCS_BUCKET=

# Path to GCP service-account JSON with Storage Object Admin on the bucket
GOOGLE_APPLICATION_CREDENTIALS=/Users/black/.config/gcp/finishing-agent-sa.json

# Polling interval in seconds (default 30)
POLL_INTERVAL_SECONDS=30

# Auto-detect on macOS, but you can override
# RESOLVE_SCRIPT_API=/Library/Application Support/Blackmagic Design/DaVinci Resolve/Developer/Scripting
# RESOLVE_SCRIPT_LIB=/Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/Libraries/Fusion/fusionscript.so
