generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  STARTER
  GROWTH
  SCALE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum PlatformType {
  INSTAGRAM
  FACEBOOK
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  GOOGLE_ANALYTICS
  SNAPCHAT
}

enum AssetKind {
  VIDEO_FINAL
  VIDEO_VARIANT
  VIDEO_CLIP
  IMAGE_POSTER
  IMAGE_STILL
  AUDIO_NARRATION
  AUDIO_TRACK
  POEM_TEXT
  CAPTION_TEXT
}

enum Placement {
  FEED
  STORY
  REEL
  SHORT
  CAROUSEL
  HIGHLIGHT
  SPOTLIGHT
  LONG_FORM
  COMMUNITY_POST
}

enum EngagementType {
  COMMENT
  REPLY_TO_COMMENT
  MENTION
  DM
  QUOTE
  STORY_REPLY
}

enum DraftStatus {
  PENDING
  AUTO_APPROVED
  APPROVED
  SENT
  EDITED_SENT
  SKIPPED
  FAILED
}

enum ContactTier {
  COLD
  WARM
  LOYAL
  VIP
  MUTED
  BLOCKED
}

enum IdeaStatus {
  RAW
  HOOK
  SCRIPT
  PRODUCING
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  name           String?
  businessName   String?
  businessType   String?
  industry       String?
  tier           SubscriptionTier @default(STARTER)
  onboarded      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  autoReplySettings Json?
  voicePersonaId    String?

  sessions        Session[]
  campaigns       Campaign[]
  calendarEntries CalendarEntry[]
  platforms       Platform[]
  chatSessions    ChatSession[]
  assets          Asset[]
  contacts        Contact[]
  comments        Comment[]
  directMessages  DirectMessage[]
  draftReplies    DraftReply[]
  ideas           Idea[]
  storyArcs       StoryArc[]
  inspirations    Inspiration[]
  tracks          Track[]
  highlights      HighlightCollection[]
  finishingJobs   FinishingJob[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("sessions")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("chat_sessions")
}

model Message {
  id            String      @id @default(cuid())
  chatSessionId String
  role          MessageRole
  content       String
  createdAt     DateTime    @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
  @@map("messages")
}

model Campaign {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  goal        String?
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries CalendarEntry[]

  @@index([userId])
  @@map("campaigns")
}

model CalendarEntry {
  id             String        @id @default(cuid())
  userId         String
  campaignId     String?
  platform       PlatformType
  platforms      PlatformType[]
  placement      Placement     @default(FEED)
  title          String
  content        String
  perPlatform    Json?
  mediaUrl       String?
  assetId        String?
  variantId      String?
  trackId        String?
  coverFrameSec  Float?
  source         String?
  repurposedFrom String?
  scheduledAt    DateTime
  publishedAt    DateTime?
  platformPostIds Json?
  status         ContentStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  asset    Asset?         @relation(fields: [assetId], references: [id], onDelete: SetNull)
  variant  AssetVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  track    Track?         @relation(fields: [trackId], references: [id], onDelete: SetNull)
  analytics Analytics[]

  @@index([userId, scheduledAt])
  @@index([status])
  @@map("calendar_entries")
}

model Platform {
  id             String       @id @default(cuid())
  userId         String
  type           PlatformType
  accountName    String
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  grantedScopes  String[]
  manualMode     Boolean      @default(false)
  connected      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("platforms")
}

model Analytics {
  id              String   @id @default(cuid())
  calendarEntryId String
  impressions     Int      @default(0)
  engagement      Int      @default(0)
  clicks          Int      @default(0)
  shares          Int      @default(0)
  comments        Int      @default(0)
  saves           Int      @default(0)
  watchTimeSec   Int      @default(0)
  recordedAt      DateTime @default(now())

  calendarEntry CalendarEntry @relation(fields: [calendarEntryId], references: [id], onDelete: Cascade)

  @@index([calendarEntryId])
  @@map("analytics")
}

model Asset {
  id          String    @id @default(cuid())
  userId      String
  kind        AssetKind
  projectId   String?
  episode     Int?
  title       String?
  archetype   String?
  mode        String?
  gcsUri      String
  publicUrl   String?
  durationSec Int?
  width       Int?
  height      Int?
  bpm         Float?
  trackId     String?
  poemText    String?
  metadata    Json      @default("{}")
  pineconeIds String[]
  embeddedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           Track?          @relation(fields: [trackId], references: [id], onDelete: SetNull)
  variants        AssetVariant[]
  calendarEntries CalendarEntry[]
  ideas           Idea[]

  @@index([userId, kind])
  @@index([projectId])
  @@map("assets")
}

model AssetVariant {
  id            String   @id @default(cuid())
  assetId       String
  aspectRatio   String
  durationSec   Int?
  gcsUri        String
  gradedFor     String?
  coverFrameSec Float?
  createdAt     DateTime @default(now())

  asset           Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  calendarEntries CalendarEntry[]

  @@index([assetId])
  @@map("asset_variants")
}

model Track {
  id          String   @id @default(cuid())
  userId      String
  gcsUri      String
  title       String?
  artist      String?
  bpm         Float?
  musicalKey  String?
  energy      Float?
  peakAt      Float[]
  durationSec Int
  mood        String?
  licensed    Boolean  @default(false)
  pineconeId  String?
  createdAt   DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets          Asset[]
  calendarEntries CalendarEntry[]

  @@index([userId])
  @@map("tracks")
}

model HighlightCollection {
  id           String       @id @default(cuid())
  userId       String
  platform     PlatformType
  title        String
  coverAssetId String?
  order        Int          @default(0)
  assetIds     String[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
  @@map("highlight_collections")
}

model Contact {
  id               String       @id @default(cuid())
  userId           String
  platform         PlatformType
  externalId       String
  username         String?
  displayName      String?
  avatarUrl        String?
  tier             ContactTier  @default(COLD)
  profile          Json         @default("{}")
  notes            String?
  firstSeenAt      DateTime     @default(now())
  lastSeenAt       DateTime     @default(now())
  totalEngagements Int          @default(0)
  autoApprove      Boolean      @default(false)
  muted            Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments       Comment[]
  directMessages DirectMessage[]
  drafts         DraftReply[]

  @@unique([userId, platform, externalId])
  @@index([userId, tier])
  @@index([lastSeenAt])
  @@map("contacts")
}

model Comment {
  id               String         @id @default(cuid())
  userId           String
  contactId        String
  calendarEntryId  String?
  platform         PlatformType
  externalId       String
  parentExternalId String?
  type             EngagementType @default(COMMENT)
  text             String
  mediaUrl         String?
  sentiment        Float?
  intent           String?
  pineconeId       String?
  receivedAt       DateTime
  createdAt        DateTime       @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  drafts  DraftReply[]

  @@unique([platform, externalId])
  @@index([userId, receivedAt])
  @@index([contactId])
  @@map("comments")
}

model DirectMessage {
  id         String       @id @default(cuid())
  userId     String
  contactId  String
  platform   PlatformType
  externalId String
  direction  String
  text       String
  mediaUrl   String?
  threadId   String?
  sentiment  Float?
  pineconeId String?
  sentAt     DateTime
  createdAt  DateTime     @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  drafts  DraftReply[]

  @@unique([platform, externalId])
  @@index([userId, sentAt])
  @@index([contactId, sentAt])
  @@index([threadId])
  @@map("direct_messages")
}

model DraftReply {
  id             String       @id @default(cuid())
  userId         String
  contactId      String
  commentId      String?
  dmId           String?
  platform       PlatformType
  draftText      String
  finalText      String?
  confidence     Float
  groundingRefs  Json?
  status         DraftStatus  @default(PENDING)
  scheduledFor   DateTime?
  sentAt         DateTime?
  platformPostId String?
  error          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  comment Comment?       @relation(fields: [commentId], references: [id], onDelete: SetNull)
  dm      DirectMessage? @relation(fields: [dmId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([scheduledFor])
  @@map("draft_replies")
}

model StoryArc {
  id              String    @id @default(cuid())
  userId          String
  title           String
  archetypeMode   String?
  description     String?
  targetEpisodes  Int?
  bibleRef        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ideas Idea[]

  @@index([userId])
  @@map("story_arcs")
}

model Idea {
  id              String     @id @default(cuid())
  userId          String
  storyArcId      String?
  title           String
  body            String?
  voiceMemoGcsUri String?
  imageRefs       String[]
  assetId         String?
  hooks           Json?
  platforms       PlatformType[]
  status          IdeaStatus @default(RAW)
  pineconeId      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyArc StoryArc? @relation(fields: [storyArcId], references: [id], onDelete: SetNull)
  asset    Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("ideas")
}

model Inspiration {
  id         String       @id @default(cuid())
  userId     String
  sourceUrl  String
  platform   PlatformType?
  mediaGcsUri String?
  title      String?
  notes      String?
  tags       String[]
  pineconeId String?
  scrapedAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("inspirations")
}

// WHY: Finishing jobs queued for the local DaVinci agent. The strategist
// emits FINISH_IN_DAVINCI after the Sound Engineer locks the score; the
// ChatPanel handler creates a row here; the user's Mac-local Python agent
// polls /api/finish/davinci/poll, claims the job, drives DaVinci Resolve
// via its Python API to assemble + grade + render multi-format outputs,
// and reports completion via /api/finish/davinci/update.
enum FinishingJobStatus {
  QUEUED
  IN_PROGRESS
  COMPLETE
  FAILED
}

model FinishingJob {
  id          String             @id @default(cuid())
  userId      String
  projectId   String?
  status      FinishingJobStatus @default(QUEUED)
  // Spec is the full job payload: scene URLs, audio URL, target formats,
  // brand LUT id, duration, project name. Shape evolves so JSON is fine.
  spec        Json
  // Result is the array of rendered output URLs (one per format) + any
  // metadata the agent wants to surface back. Populated on completion.
  result      Json?
  error       String?
  agentVersion String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("finishing_jobs")
}
